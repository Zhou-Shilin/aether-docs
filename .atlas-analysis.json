  "keyFeatures": [
    "Multi-provider LLM support (OpenAI, Anthropic, Google, DeepSeek, Groq, Mistral, Cloudflare, and more)",
    "Built-in Alpine Linux VM for shell command and tool execution",
    "Termux and Shizuku integration for Android device automation",
    "Hot-reloadable TypeScript/JavaScript Script Mod API v2",
    "Native Kotlin/DEX Mod system for full Android and Compose access",
    "Declarative UI system for extension-provided surfaces and component replacement",
    "Pi agent framework integration with tool, command, and hook registration",
    "Persistent per-extension storage and global app state transactions",
    "Operation interception chain (chat.new, skills.selection)",
    "Discoverable service registry with priority-based override support",
    "WebView escape hatch for HTML micro-UIs inside extensions",
    "Native Mod Safe Mode for crash-loop recovery"
  ],
  "publicApiSurface": [
    "AetherExtensionAPI.registerSurface(slot, definition)",
    "AetherExtensionAPI.registerComponent(target, definition)",
    "AetherExtensionAPI.registerPage(definition)",
    "AetherExtensionAPI.registerAction(id, handler)",
