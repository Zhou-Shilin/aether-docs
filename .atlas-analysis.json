    "AetherExtensionAPI.state.transaction(operations)",
    "AetherExtensionAPI.storage.get/set/delete/clear/snapshot()",
    "AetherExtensionAPI.host.invoke(method, args?)",
    "AetherExtensionAPI.services.list/describe/invoke()",
    "AetherExtensionAPI.notify(message, level?)",
    "AetherExtensionAPI.invalidate()",
    "defineAetherExtension(factory)",
    "ui.text / ui.code / ui.column / ui.row / ui.box / ui.scroll / ui.card",
    "ui.button / ui.iconButton / ui.switch / ui.input / ui.spacer / ui.progress",
    "ui.pageButton / ui.web / ui.core",
    "AetherNativeMod.onLoad(context) / onUnload()",
    "AetherNativeModContext.registerService(id, priority, methods, handler)",
    "AetherNativeModContext.intercept(operation, priority, handler)",
    "AetherNativeModContext.registerComponent(target, id, mode, priority, renderer)",
    "host method: app.getState / app.setDraftInput / app.appendDraftInput / app.sendMessage",
    "host method: app.newChat / app.selectSession / app.openScreen / app.pauseGeneration",
    "host method: app.setReasoningEffort / app.setAgentMode / app.setModel / app.notify",
    "host method: settings.get / settings.patch / runtime.execute",
    "service: skills.list / skills.getSelection / skills.setSelection / skills.setSelected",
    "service: state.get / state.transaction",
    "state paths: draft_input, selected_skill_ids, default_skill_ids, agent_mode_enabled, selected_model_key, screen",
